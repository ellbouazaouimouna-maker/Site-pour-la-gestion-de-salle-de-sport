<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.club.controller.adherent.AdherentDashboardController"
            styleClass="main-layout">
    <left>
        <VBox styleClass="sidebar" prefWidth="215">
            <!-- Brand -->
            <VBox styleClass="sidebar-brand" spacing="4">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="🏋" style="-fx-font-size:20px;"/>
                    <Label text="GYM System" styleClass="sidebar-logo"/>
                </HBox>
            </VBox>
            <!-- Nav -->
            <VBox styleClass="sidebar-nav" VBox.vgrow="ALWAYS" spacing="4">
                <Button fx:id="btnProfil" text="  🏠   Accueil" styleClass="nav-item,nav-active"
                        maxWidth="Infinity" onAction="#showAccueil"/>
                <Button fx:id="btnProfilPage" text="  👤   Mon Profil" styleClass="nav-item"
                        maxWidth="Infinity" onAction="#showProfil"/>
                <Button fx:id="btnActivites" text="  📅   Mes Activités" styleClass="nav-item"
                        maxWidth="Infinity" onAction="#showActivites"/>
                <Button fx:id="btnPaiement" text="  💳   Paiements" styleClass="nav-item"
                        maxWidth="Infinity" onAction="#showPaiement"/>
                <Button fx:id="btnMdp" text="  🔒   Changer mot de passe" styleClass="nav-item"
                        maxWidth="Infinity" onAction="#showChangerMdp"/>
            </VBox>
            <!-- Footer -->
            <VBox styleClass="sidebar-footer" spacing="10">
                <Separator/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label fx:id="avatarLabel" text="A" styleClass="sidebar-avatar"/>
                    <VBox spacing="2">
                        <Label fx:id="nameLabel" text="" styleClass="sidebar-user-name"/>
                        <Label fx:id="emailLabel" text="" styleClass="sidebar-user-email"/>
                    </VBox>
                </HBox>
                <Button text="  🚪   Déconnexion" styleClass="btn-logout"
                        maxWidth="Infinity" onAction="#handleLogout"/>
            </VBox>
        </VBox>
    </left>
    <center>
        <VBox styleClass="main-content">
            <!-- Top bar -->
            <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="16">
                <Label fx:id="pageTitle" text="Mon Profil" styleClass="page-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="dateLabel" styleClass="date-label"/>
            </HBox>
            <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS" styleClass="content-area"/>
        </VBox>
    </center>
</BorderPane>
