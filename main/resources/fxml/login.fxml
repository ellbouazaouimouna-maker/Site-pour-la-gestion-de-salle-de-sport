<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.club.controller.auth.LoginController"
           styleClass="root-stack">
    <HBox>
        <!-- GAUCHE : fond sombre + texte centré -->
        <StackPane prefWidth="460" styleClass="login-left-stack">
            <VBox styleClass="login-left-bg"/>
            <VBox styleClass="login-left-overlay"/>
            <VBox alignment="CENTER" spacing="12">
                <Label text="Welcome" styleClass="login-hero-title"/>
                <Label text="Move. Grow. Win." styleClass="login-hero-sub"/>
            </VBox>
        </StackPane>

        <!-- DROITE : formulaire -->
        <VBox styleClass="login-right-panel" HBox.hgrow="ALWAYS" alignment="CENTER">
            <VBox styleClass="login-form-card" spacing="0" maxWidth="480">

                <VBox styleClass="login-form-header" spacing="6">
                    <Label text="Connexion à votre compte" styleClass="login-form-title"/>
                    <Label text="Accédez à votre espace membre" styleClass="login-form-subtitle"/>
                </VBox>

                <VBox styleClass="login-form-body" spacing="16">
                    <VBox spacing="6">
                        <Label text="Nom d'utilisateur" styleClass="field-label"/>
                        <TextField fx:id="emailField" promptText="Entrez votre nom d'utilisateur" styleClass="input-field"/>
                    </VBox>
                    <VBox spacing="6">
                        <Label text="Mot de passe" styleClass="field-label"/>
                        <PasswordField fx:id="passwordField" promptText="Entrez votre mot de passe" styleClass="input-field"/>
                    </VBox>
                    <HBox alignment="CENTER_LEFT">
                        <CheckBox fx:id="sesouvenir" text="Se souvenir de moi" style="-fx-font-size:12px; -fx-text-fill:#64748b;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="forgotLabel" text="Mot de passe oublié ?" style="-fx-font-size:12px; -fx-text-fill:#2563eb; -fx-cursor:hand;" onMouseClicked="#handleForgotPassword"/>
                    </HBox>
                    <Label fx:id="errorLabel" styleClass="error-label" wrapText="true" managed="false" visible="false"/>
                    <Button fx:id="loginButton" text="Se connecter" styleClass="btn-login-full"
                            maxWidth="Infinity" onAction="#handleLogin"/>
                    <HBox alignment="CENTER" spacing="10">
                        <Separator HBox.hgrow="ALWAYS"/>
                        <Label text="ou" style="-fx-text-fill:#94a3b8; -fx-font-size:12px;"/>
                        <Separator HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <HBox spacing="12">
                        <Hyperlink fx:id="registerLink" text="Créer un compte"
                                   styleClass="btn-login-outline"
                                   onAction="#handleRegister"
                                   HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Button text="Connexion Admin" styleClass="btn-login-outline-blue"
                                onAction="#handleLogin"
                                HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    </HBox>
                    <Separator/>
                    <VBox spacing="5">
                        <Label text="Besoin d'aide ?" style="-fx-font-size:12px; -fx-text-fill:#64748b; -fx-font-weight:bold;"/>
                        <Label fx:id="telephoneLabel" text="📞  06XXXXXXXX" style="-fx-font-size:12px; -fx-text-fill:#64748b;"/>
                        <Label fx:id="emailContactLabel" text="✉  gymfitness@gmail.com" style="-fx-font-size:12px; -fx-text-fill:#64748b;"/>
                    </VBox>
                    <Label text="© 2026 Gym Management System"
                           style="-fx-font-size:11px; -fx-text-fill:#cbd5e1;" maxWidth="Infinity" alignment="CENTER"/>
                </VBox>
            </VBox>
        </VBox>
    </HBox>
</StackPane>
